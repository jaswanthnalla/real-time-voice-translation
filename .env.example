# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
TWILIO_WEBHOOK_URL=https://your-domain.com/webhooks/twilio

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json
GOOGLE_CLOUD_REGION=us-central1

# Google Cloud Speech-to-Text
GOOGLE_SPEECH_LANGUAGE_CODE=en-US
GOOGLE_SPEECH_MODEL=phone_call
GOOGLE_SPEECH_USE_ENHANCED=true
GOOGLE_SPEECH_ENABLE_AUTOMATIC_PUNCTUATION=true

# Google Cloud Translation
GOOGLE_TRANSLATE_PROJECT_ID=your_google_translate_project_id

# Google Cloud Text-to-Speech
GOOGLE_TTS_VOICE_NAME=en-US-Neural2-A
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_SSML_GENDER=NEUTRAL

# Azure Cognitive Services (Alternative)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=your_azure_region
AZURE_TRANSLATOR_KEY=your_azure_translator_key
AZURE_TRANSLATOR_REGION=your_azure_translator_region

# OpenAI Configuration (for summarization)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/voice_translation
REDIS_URL=redis://localhost:6379

# WebSocket Configuration
WEBSOCKET_PORT=3002
WEBSOCKET_CORS_ORIGIN=http://localhost:3000

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here
API_KEY=your_api_key_here
ENCRYPTION_KEY=your_encryption_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WEBHOOK_MAX=1000

# Audio Processing
AUDIO_SAMPLE_RATE=8000
AUDIO_CHANNELS=1
AUDIO_ENCODING=LINEAR16
AUDIO_CHUNK_SIZE=1024
AUDIO_BUFFER_SIZE=4096

# Translation Pipeline
TRANSLATION_CACHE_TTL=3600
TRANSLATION_BATCH_SIZE=10
TRANSLATION_TIMEOUT_MS=5000
TRANSLATION_MAX_RETRIES=3

# Latency Optimization
ENABLE_AUDIO_STREAMING=true
ENABLE_PARTIAL_RESULTS=true
ENABLE_VOICE_ACTIVITY_DETECTION=true
ENABLE_ECHO_CANCELLATION=true
ENABLE_NOISE_SUPPRESSION=true

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true

# Monitoring and Health Checks
HEALTH_CHECK_INTERVAL=30000
METRICS_COLLECTION_INTERVAL=60000
ENABLE_PROMETHEUS_METRICS=true
PROMETHEUS_PORT=9090

# Storage Configuration
STORAGE_PROVIDER=local
AWS_S3_BUCKET=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# CDN Configuration
CDN_URL=https://your-cdn-domain.com
ENABLE_CDN=false

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
FROM_EMAIL=noreply@yourapp.com

# Webhook Security
WEBHOOK_SECRET=your_webhook_secret_here
ENABLE_WEBHOOK_SIGNATURE_VERIFICATION=true

# Feature Flags
ENABLE_CONVERSATION_SUMMARY=true
ENABLE_TRANSCRIPT_STORAGE=true
ENABLE_CALL_RECORDING=false
ENABLE_REAL_TIME_ANALYTICS=true
ENABLE_MULTI_LANGUAGE_DETECTION=true
ENABLE_VOICE_CLONING=false

# Performance Tuning
MAX_CONCURRENT_CALLS=100
MAX_CALL_DURATION_MINUTES=60
AUDIO_PROCESSING_THREADS=4
TRANSLATION_WORKER_THREADS=2

# Client Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_SOCKET_URL=http://localhost:3001
REACT_APP_ENABLE_DEBUG=true
REACT_APP_DEFAULT_SOURCE_LANGUAGE=en
REACT_APP_DEFAULT_TARGET_LANGUAGE=es

# Development Configuration
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:3000
ENABLE_SWAGGER_DOCS=true
SWAGGER_PATH=/api-docs

# Production Configuration
ENABLE_HTTPS=false
SSL_CERT_PATH=path/to/ssl/cert.pem
SSL_KEY_PATH=path/to/ssl/key.pem
ENABLE_COMPRESSION=true
ENABLE_HELMET_SECURITY=true

# Backup Configuration
ENABLE_AUTO_BACKUP=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=backups/

# Analytics Configuration
GOOGLE_ANALYTICS_ID=your_google_analytics_id
ENABLE_USER_ANALYTICS=false
ANALYTICS_SAMPLE_RATE=0.1

# Error Reporting
SENTRY_DSN=your_sentry_dsn_here
ENABLE_ERROR_REPORTING=false

# Cache Configuration
CACHE_PROVIDER=redis
CACHE_TTL_SECONDS=3600
ENABLE_RESPONSE_CACHING=true

# Load Balancing
ENABLE_LOAD_BALANCING=false
LOAD_BALANCER_ALGORITHM=round_robin
HEALTH_CHECK_PATH=/health

# Scaling Configuration
AUTO_SCALING_ENABLED=false
MIN_INSTANCES=1
MAX_INSTANCES=10
CPU_THRESHOLD=70
MEMORY_THRESHOLD=80