{
  "name": "@voicetranslate/core",
  "version": "1.0.0",
  "description": "Production-grade real-time voice translation software with WebSocket support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "voice-translate": "./bin/cli.js"
  },
  "scripts": {
    "build": "npm run clean && npm run build:server && npm run build:client && npm run build:types",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "webpack --config webpack.prod.js",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "clean": "rimraf dist",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --exec ts-node src/server/index.ts",
    "dev:client": "webpack serve --config webpack.dev.js",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.{ts,js} --fix",
    "format": "prettier --write src/**/*.{ts,js,json}",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit && snyk test",
    "docker:build": "docker build -t voice-translate:latest .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "start": "node dist/server/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/server/index.js",
    "docs:generate": "typedoc src --out docs",
    "docs:serve": "http-server docs -p 8080",
    "release": "semantic-release",
    "health-check": "node scripts/health-check.js"
  },
  "keywords": [
    "voice-translation",
    "real-time",
    "websocket",
    "speech-to-text",
    "text-to-speech",
    "twilio",
    "production-ready",
    "enterprise"
  ],
  "author": "Voice Translation Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/voice-translate-core.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/voice-translate-core/issues"
  },
  "homepage": "https://github.com/your-org/voice-translate-core#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "twilio": "^4.15.0",
    "@google-cloud/speech": "^6.0.0",
    "@google-cloud/translate": "^8.0.2",
    "@google-cloud/text-to-speech": "^5.0.1",
    "openai": "^4.0.0",
    "axios": "^1.5.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "node-cache": "^5.1.2",
    "redis": "^4.6.8",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "ws": "^8.13.0",
    "joi": "^17.9.2",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "prom-client": "^14.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/uuid": "^9.0.2",
    "@types/ws": "^8.5.5",
    "@types/compression": "^1.7.2",
    "@types/morgan": "^1.9.4",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/jest": "^29.5.3",
    "@types/supertest": "^2.0.12",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "eslint": "^8.46.0",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.1",
    "concurrently": "^8.2.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "html-webpack-plugin": "^5.5.3",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.4.4",
    "typedoc": "^0.24.8",
    "http-server": "^14.1.1",
    "semantic-release": "^21.0.7",
    "snyk": "^1.1193.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3"
  },
  "peerDependencies": {},
  "files": [
    "dist",
    "bin",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test && npm run typecheck"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}