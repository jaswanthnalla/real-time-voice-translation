{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./dist/client",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "src/client/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "src/server/**/*",
    "node_modules",
    "dist"
  ]
}
